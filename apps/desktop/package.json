{
  "name": "@sillpak/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && electron dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@sillpak/contracts": "workspace:*",
    "@parcel/watcher": "2.5.6",
    "node-pty": "1.1.0"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "electron": "42.6.0",
    "electron-builder": "26.0.12",
    "typescript": "5.9.3"
  }
}
