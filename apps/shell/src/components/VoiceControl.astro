<div class="voice-control" data-voice-control transition:persist="sillpak-voice">
  <button type="button" class="text-command" data-voice-toggle>Dictate</button>
  <span class="instrument-status" data-voice-status>idle</span>
  <select aria-label="Dictation destination" data-voice-target>
    <option value="terminal">terminal input</option>
    <option value="editor">active editor</option>
  </select>
</div>
