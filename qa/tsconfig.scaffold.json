{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": [],
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "baseUrl": "..",
    "paths": {
      "@sillpak/contracts": [
        "packages/contracts/src/index.ts"
      ]
    }
  },
  "include": [
